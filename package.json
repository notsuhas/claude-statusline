{
  "name": "@notsuhas/claude-statusline",
  "version": "1.1.1",
  "description": "Robbyrussell-themed status line for Claude Code with rate limits, session time, and git info",
  "bin": {
    "claude-statusline": "./bin/install.js"
  },
  "scripts": {
    "prepublishOnly": "bash bin/build.sh",
    "version": "git add -A",
    "postversion": "git push origin main --follow-tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/notsuhas/claude-statusline.git"
  },
  "homepage": "https://github.com/notsuhas/claude-statusline#readme",
  "bugs": {
    "url": "https://github.com/notsuhas/claude-statusline/issues"
  },
  "files": [
    "bin/",
    "dist/",
    "src/",
    "install.sh",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "statusline",
    "robbyrussell",
    "cli",
    "terminal",
    "rate-limits"
  ],
  "license": "MIT",
  "author": "Suhas"
}
